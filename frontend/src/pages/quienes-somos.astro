---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quiénes somos">

  <!-- Hero -->
  <section class="py-16 px-4 text-center text-white" style="background:#006847">
    <p class="text-sm" style="opacity:0.75">
      <a href="/" class="hover:underline">Inicio</a> · Quiénes somos
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mt-2">Quiénes somos</h1>
    <p class="mt-2" style="opacity:0.8">UMAE Hospital de Especialidades IMSS Puebla</p>
  </section>

  <!-- Contenido -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Historia -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-gray-800 mb-4 border-l-4 border-imss-green pl-4">
          Historia
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Lorem ipsum — placeholder. El UMAE Hospital de Especialidades del IMSS en Puebla
          fue fundado con el objetivo de brindar atención médica especializada de alta calidad
          a los derechohabientes de la región. Con décadas de trayectoria, el hospital se ha
          consolidado como un referente en salud especializada en el sureste de México.
        </p>
      </div>

      <!-- Nuestro equipo -->
      <div class="mb-10">
        <h2 class="text-xl font-bold text-gray-800 mb-4 border-l-4 border-imss-green pl-4">
          Nuestro equipo
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Contamos con un equipo multidisciplinario de médicos especialistas, enfermeras,
          técnicos y personal administrativo comprometido con la excelencia en la atención
          médica y el bienestar de nuestros pacientes.
        </p>
      </div>

      <!-- Estadísticas -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mt-10">
        <div class="bg-imss-green-light rounded-xl p-6 text-center">
          <p class="text-3xl font-bold text-imss-green">500+</p>
          <p class="text-sm text-gray-600 mt-1">Camas</p>
        </div>
        <div class="bg-imss-green-light rounded-xl p-6 text-center">
          <p class="text-3xl font-bold text-imss-green">1,200+</p>
          <p class="text-sm text-gray-600 mt-1">Médicos especialistas</p>
        </div>
        <div class="bg-imss-green-light rounded-xl p-6 text-center">
          <p class="text-3xl font-bold text-imss-green">50+</p>
          <p class="text-sm text-gray-600 mt-1">Especialidades</p>
        </div>
      </div>

    </div>
  </section>

</Layout>
