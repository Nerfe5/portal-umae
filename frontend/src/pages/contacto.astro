---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto">

  <!-- Hero -->
  <section class="py-16 px-4 text-center text-white" style="background:#006847">
    <p class="text-sm" style="opacity:0.75">
      <a href="/" class="hover:underline">Inicio</a> · Contacto
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mt-2">Contacto</h1>
    <p class="mt-2" style="opacity:0.8">Ubicación y datos de contacto</p>
  </section>

  <!-- Contenido principal -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Columna izquierda: contacto y soporte -->
      <div>
        <h2 class="text-xl font-bold text-gray-800 mb-6">Contacto y soporte del portal</h2>

        <!-- Administrador -->
        <div class="flex items-start gap-4 mb-6">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#006847"
            viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982
                 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112
                 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
              Administrador del portal
            </p>
            <p class="text-gray-700">División de Ingeniería Biomédica</p>
          </div>
        </div>

        <!-- Correo -->
        <div class="flex items-start gap-4 mb-6">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#006847"
            viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0
                 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0
                 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25
                 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
              Correo electrónico
            </p>
            <a href="mailto:marco.coeto@imss.gob.mx" class="hover:underline" style="color:#006847">
              marco.coeto@imss.gob.mx
            </a>
          </div>
        </div>

        <!-- Teléfono -->
        <div class="flex items-start gap-4 mb-6">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#006847"
            viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372
                 c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97
                 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441
                 .004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125
                 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Teléfono</p>
            <p class="text-gray-700">222 2 42 45 20 al 26</p>
            <p class="text-gray-700">Ext. 61904 · División de Ingeniería Biomédica</p>
          </div>
        </div>

        <!-- Ubicación -->
        <div class="flex items-start gap-4 mb-6">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#006847"
            viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0
                 0115 0z"/>
          </svg>
          <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Ubicación</p>
            <p class="text-gray-700">Calle 2 Norte No. 2004, Col. Centro</p>
            <p class="text-gray-700">Puebla, Pue. C.P. 72000</p>
          </div>
        </div>

      </div>

      <!-- Columna derecha: mapa -->
      <div>
        <h2 class="text-xl font-bold text-gray-800 mb-6">Ubicación</h2>
        <iframe
          src="https://maps.google.com/maps?q=Calle+2+Norte+2004,+Puebla,+Mexico&output=embed"
          class="w-full h-80 rounded-xl border border-gray-200 shadow-sm"
          loading="lazy"
          allowfullscreen
          title="Ubicación UMAE Hospital de Especialidades IMSS Puebla"
        ></iframe>
      </div>

    </div>
  </section>

  <!-- Aviso -->
  <section class="bg-gray-50 py-10 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-sm text-gray-500">
        Para reportar problemas técnicos con el portal, comunícate con la
        División de Ingeniería Biomédica al teléfono 222 2 42 45 20 al 26,
        ext. 61904, o escribe a
        <a href="mailto:marco.coeto@imss.gob.mx" class="hover:underline" style="color:#006847">
          marco.coeto@imss.gob.mx
        </a>
      </p>
    </div>
  </section>

</Layout>
