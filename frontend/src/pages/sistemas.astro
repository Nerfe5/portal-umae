---
import Layout from '../layouts/Layout.astro';

const sistemas = [
  // ── Clínicos ──────────────────────────────────────────
  { nombre: "CADIT",              descripcion: "Sistema de Consulta y Atención Digital",                     href: "http://produccionsicadit.imss.gob.mx/psp/ps/?&cmd=login&languageCd=ESP&",                                                                                                          categoria: "Clínicos" },
  { nombre: "ECE - IMSS",         descripcion: "Expediente Clínico Electrónico",                             href: "http://ece.imss.gob.mx/ece/pages/acceso/login.jsf",                                                                                                                             categoria: "Clínicos" },
  { nombre: "Rayos X",            descripcion: "Sistema de Imágenes Diagnósticas (HisWeb)",                  href: "http://172.27.69.8/HisWeb",                                                                                                                                                     categoria: "Clínicos" },
  { nombre: "PHEDS",              descripcion: "Sistema Hospitalario de Expediente Digital",                 href: "https://pheds.imss.gob.mx/siah/login.html",                                                                                                                                    categoria: "Clínicos" },
  { nombre: "PHEDS Prog. QX",     descripcion: "Programación Quirúrgica",                                   href: "https://pheds.imss.gob.mx/sq/",                                                                                                                                                categoria: "Clínicos" },
  { nombre: "Pasteur",            descripcion: "Sistema de Laboratorio Pasteur",                             href: "http://172.27.69.57:80/",                                                                                                                                                      categoria: "Clínicos" },
  { nombre: "Winlab",             descripcion: "Sistema de Resultados de Laboratorio",                       href: "http://11.45.22.74/WinlabWeb/ww/login.aspx",                                                                                                                                   categoria: "Clínicos" },
  { nombre: "RIC",                descripcion: "Registro Institucional de Cáncer",                          href: "http://172.22.235.16/sric/",                                                                                                                                                   categoria: "Clínicos" },
  { nombre: "CIH",                descripcion: "Centro de Información Hospitalaria",                         href: "http://172.24.249.4/cih",                                                                                                                                                      categoria: "Clínicos" },
  // ── Administrativos ───────────────────────────────────
  { nombre: "SAI",                descripcion: "Sistema de Administración Institucional",                    href: "http://sai.imss.gob.mx/",                                                                                                                                                     categoria: "Administrativos" },
  { nombre: "SIE",                descripcion: "Sistema de Información Estadística",                         href: "http://172.24.249.2/",                                                                                                                                                         categoria: "Administrativos" },
  { nombre: "PREI",               descripcion: "Presupuesto e Inversión",                                    href: "http://prei.imss.gob.mx/",                                                                                                                                                    categoria: "Administrativos" },
  { nombre: "PREI 2",             descripcion: "Presupuesto e Inversión — versión 2",                        href: "http://prei.imss.gob.mx/prei2/",                                                                                                                                              categoria: "Administrativos" },
  { nombre: "Pago de Cuentas",    descripcion: "Consulta y gestión de pago de cuentas",                     href: "http://172.24.81.105/Anexo2/consulta_de_anexo_3list.php",                                                                                                                     categoria: "Administrativos" },
  { nombre: "Tarjetón Digital",   descripcion: "Consulta de tarjetón digital del personal",                 href: "http://rh.imss.gob.mx/TarjetonDigital/",                                                                                                                                      categoria: "Administrativos" },
  { nombre: "Biométricos",        descripcion: "Registro y consulta de datos biométricos",                  href: "http://siapportal.imss.gob.mx/biometrico/",                                                                                                                                   categoria: "Administrativos" },
  { nombre: "CVOED",              descripcion: "Control y Validación de Operaciones",                        href: "http://cvoed.imss.gob.mx/",                                                                                                                                                   categoria: "Administrativos" },
  { nombre: "MAAGTIC-SI",         descripcion: "Sistema de Gestión de TIC",                                  href: "http://maagtic/Maagticsi/index.html",                                                                                                                                          categoria: "Administrativos" },
  // ── Información ───────────────────────────────────────
  { nombre: "Digitalización Nacional", descripcion: "Sistema de Digitalización de Documentos",              href: "http://172.25.0.97:8080/2023/DigitalizacionUrls/index.php",                                                                                                                   categoria: "Información" },
  { nombre: "Acceder Unificado",  descripcion: "Acceso unificado a servicios digitales IMSS",               href: "http://ssoadmin.imss.gob.mx/openam_10.0.0/XUI/?realm=ventanilla&goto=http://serviciosdigitalesinterno.imss.gob.mx/gestionDerechohabientes-web/j_spring_security_check",        categoria: "Información" },
  { nombre: "Intranet",           descripcion: "Red interna de información institucional",                   href: "http://intranet/Paginas/index.aspx",                                                                                                                                          categoria: "Información" },
  { nombre: "Mejores Prácticas",  descripcion: "Repositorio de mejores prácticas institucionales",          href: "http://intranet:55511/uoc/Paginas/mejorespracticas.aspx",                                                                                                                     categoria: "Información" },
  { nombre: "COVID-19",           descripcion: "Información familiar COVID-19",                              href: "https://infofamiliarcovid.imss.gob.mx/infcovid-web/login",                                                                                                                    categoria: "Información" },
  // ── IMSS General ──────────────────────────────────────
  { nombre: "Portal IMSS",        descripcion: "Sitio oficial del Instituto Mexicano del Seguro Social",    href: "http://www.imss.gob.mx/Pages/index.aspx",                                                                                                                                     categoria: "IMSS General" },
  { nombre: "Transparencia IMSS", descripcion: "Portal de Transparencia del IMSS",                          href: "http://transparencia.imss.gob.mx/",                                                                                                                                           categoria: "IMSS General" },
  { nombre: "Correo Institucional", descripcion: "Correo electrónico institucional (Webmail)",               href: "https://outlook.office.com/mail",                                                                                                                                              categoria: "IMSS General" },
  { nombre: "Guías de Práctica Clínica", descripcion: "Guías clínicas para profesionales de salud",        href: "http://www.imss.gob.mx/profesionales-salud/gpc",                                                                                                                              categoria: "IMSS General" },
];

const categorias = ["Clínicos", "Administrativos", "Información", "IMSS General"];
---

<Layout title="Sistemas institucionales">

  <!-- Hero -->
  <section class="py-16 px-4 text-center text-white" style="background:#006847">
    <p class="text-sm" style="opacity:0.75">
      <a href="/" class="hover:underline">Inicio</a> · Sistemas institucionales
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mt-2">Sistemas institucionales</h1>
    <p class="mt-2" style="opacity:0.8">Acceso directo a los sistemas del IMSS</p>
  </section>

  <!-- Grid de sistemas agrupados por categoría -->
  <section class="bg-white py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <p class="text-gray-600 mb-10 max-w-2xl">
        Accede a los sistemas institucionales del IMSS y del hospital.
        Los sistemas con dirección IP interna (172.x.x.x) solo están
        disponibles desde la red del hospital.
      </p>

      {categorias.map(cat => (
        <div>
          <h2 class="text-lg font-semibold text-gray-700 mb-4 mt-8 pb-2 border-b border-gray-200">
            <span style="color:#006847" class="mr-2">●</span>{cat}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {sistemas.filter(s => s.categoria === cat).map(({ nombre, descripcion, href }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener"
                class="border border-gray-200 rounded-xl p-6 shadow-sm flex flex-col gap-3
                       hover:shadow-md hover:border-imss-green transition-all"
              >
                <div class="flex items-center gap-3">
                  <svg class="w-8 h-8 flex-shrink-0" fill="none" stroke="#006847"
                    viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5
                         A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                  </svg>
                  <span class="font-semibold text-gray-800">{nombre}</span>
                </div>
                <p class="text-sm text-gray-500 flex-1">{descripcion}</p>
                <p class="text-sm font-medium" style="color:#006847">Abrir sistema →</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Aviso -->
  <section class="bg-gray-50 py-10 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5 flex items-start gap-3">
        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#d97706"
          viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0
               2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898
               0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
        <p class="text-sm text-yellow-800">
          Los enlaces a sistemas institucionales son de uso exclusivo para personal
          autorizado del IMSS. El acceso no autorizado está prohibido y puede tener
          consecuencias legales.
        </p>
      </div>
    </div>
  </section>

</Layout>
