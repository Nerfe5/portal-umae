---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">

  <!-- SECCIÓN 1: Hero -->
  <section class="py-20 px-4 text-center text-white" style="background:#006847">
    <p class="text-sm uppercase tracking-widest" style="opacity:0.75">
      Instituto Mexicano del Seguro Social
    </p>
    <h1 class="text-4xl md:text-5xl font-bold mt-2">
      UMAE Hospital de Especialidades
    </h1>
    <p class="text-xl md:text-2xl mt-3" style="opacity:0.8">
      Puebla, México
    </p>
    <p class="text-base mt-6 max-w-2xl mx-auto" style="opacity:0.7">
      Portal institucional de información y acceso a servicios
      del UMAE Hospital de Especialidades IMSS Puebla.
    </p>
    <div class="mt-8 flex justify-center flex-wrap gap-4">
      <a
        href="/documentos"
        class="bg-white font-semibold px-6 py-3 rounded-lg transition-opacity hover:opacity-90"
        style="color:#006847"
      >
        Ver documentos
      </a>
      <a
        href="/contacto"
        class="border-2 border-white text-white px-6 py-3 rounded-lg transition-colors hover:bg-white/10"
      >
        Contacto
      </a>
    </div>
  </section>

  <!-- SECCIÓN 2: Accesos rápidos -->
  <section class="bg-white py-16 px-4">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-gray-800">Accesos rápidos</h2>
      <p class="text-gray-500 mt-2 mb-10">
        Navegá a las secciones principales del portal
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">

      <!-- Quiénes somos -->
      <a
        href="/quienes-somos"
        class="bg-white border border-gray-200 rounded-xl p-6 text-center shadow-sm
               hover:shadow-md hover:border-imss-green transition-all cursor-pointer"
      >
        <svg class="w-10 h-10 mx-auto mb-4" fill="none" stroke="#006847"
          viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952
               4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07
               M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766
               l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0
               3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0
               2.625 2.625 0 015.25 0z"/>
        </svg>
        <p class="font-semibold text-gray-800 mb-1">Quiénes somos</p>
        <p class="text-sm text-gray-500">Conoce nuestra historia y equipo</p>
      </a>

      <!-- Misión y Visión -->
      <a
        href="/mision-vision"
        class="bg-white border border-gray-200 rounded-xl p-6 text-center shadow-sm
               hover:shadow-md hover:border-imss-green transition-all cursor-pointer"
      >
        <svg class="w-10 h-10 mx-auto mb-4" fill="none" stroke="#006847"
          viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345
               l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557
               l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0
               L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557
               l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345
               L11.48 3.5z"/>
        </svg>
        <p class="font-semibold text-gray-800 mb-1">Misión y Visión</p>
        <p class="text-sm text-gray-500">Nuestros valores y objetivos institucionales</p>
      </a>

      <!-- Sistemas -->
      <a
        href="/sistemas"
        class="bg-white border border-gray-200 rounded-xl p-6 text-center shadow-sm
               hover:shadow-md hover:border-imss-green transition-all cursor-pointer"
      >
        <svg class="w-10 h-10 mx-auto mb-4" fill="none" stroke="#006847"
          viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0
               01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016
               13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25
               0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25
               6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5
               15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0
               0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>
        </svg>
        <p class="font-semibold text-gray-800 mb-1">Sistemas</p>
        <p class="text-sm text-gray-500">Acceso a sistemas institucionales</p>
      </a>

      <!-- Documentos -->
      <a
        href="/documentos"
        class="bg-white border border-gray-200 rounded-xl p-6 text-center shadow-sm
               hover:shadow-md hover:border-imss-green transition-all cursor-pointer"
      >
        <svg class="w-10 h-10 mx-auto mb-4" fill="none" stroke="#006847"
          viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0
               0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5
               3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504
               1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0
               00-9-9z"/>
        </svg>
        <p class="font-semibold text-gray-800 mb-1">Documentos</p>
        <p class="text-sm text-gray-500">Documentos públicos por departamento</p>
      </a>

    </div>
  </section>

  <!-- SECCIÓN 3: Aviso institucional -->
  <section class="py-12 px-4 text-center" style="background:#f0fdf4">
    <p class="text-sm text-gray-600 max-w-xl mx-auto">
      Este portal es de uso exclusivo del personal autorizado y público en general
      para consulta de información institucional. Para atención médica o urgencias,
      acuda directamente a las instalaciones del hospital.
    </p>
  </section>

</Layout>
